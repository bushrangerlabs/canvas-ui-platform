# Server
PORT=3100
HOST=0.0.0.0

# Database & data storage
DB_PATH=./data/canvas-ui.db
DATA_DIR=./data
IMAGES_DIR=./data/images

# Auth
JWT_SECRET=change-me-in-production
ADMIN_USER=admin
ADMIN_PASSWORD=canvas-ui

# Logging
LOG_LEVEL=info

# CORS — set to your editor origin in production
# e.g. CORS_ORIGINS=http://192.168.1.100:5173
CORS_ORIGINS=*

# Home Assistant Supervisor (set automatically when running as HA add-on)
# Leave blank for standalone deployments
HA_SUPERVISOR_TOKEN=
HA_SUPERVISOR_URL=http://supervisor/core
