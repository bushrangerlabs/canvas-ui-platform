# Don't send these into the Docker build context
.git
.gitignore
browser/
*.md
# Web build artifacts (rebuilt inside Docker)
web/node_modules/
web/dist/
# Server build artifacts
server/node_modules/
server/dist/
server/data/
server/*.db
server/*.db-shm
server/*.db-wal
# server/public/ is pre-built locally and must be included in the Docker context
