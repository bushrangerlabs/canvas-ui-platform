# Don't send these into the Docker build context
.git
.gitignore
browser/
*.md
# Web build artifacts (rebuilt inside Docker)
web/node_modules/
web/dist/
# Server build artifacts
server/node_modules/
server/dist/
server/data/
server/*.db
server/*.db-shm
server/*.db-wal
# The web build output that lives in server/public/
# is rebuilt in Docker — don't send local copy
server/public/
